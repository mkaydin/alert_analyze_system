# Alert Analysis RAG System - Environment Configuration Template
# Copy this file to .env and modify values as needed

# ==========================================
# Server Configuration
# ==========================================
ALERT_HOST=0.0.0.0
ALERT_PORT=8002
ALERT_RELOAD=true

# ==========================================
# Ollama Configuration
# ==========================================
# Ollama server URL (use 'http://host.docker.internal:11434' in Docker, 'http://localhost:11434' locally)
ALERT_OLLAMA_HOST=http://host.docker.internal:11434
ALERT_OLLAMA_TIMEOUT=60
ALERT_OLLAMA_CONCURRENCY=4

# Embedding model (1024 dimensions - MUST match qwen3-embedding:0.6b)
# DO NOT CHANGE without re-ingesting all data!
ALERT_EMBED_MODEL=qwen3-embedding:0.6b

# LLM model for generation
ALERT_LLM_MODEL=ornith:latest
ALERT_LLM_TEMPERATURE=0.1
ALERT_LLM_MAX_TOKENS=2048

# ==========================================
# ChromaDB Configuration
# ==========================================
ALERT_CHROMADB_PATH=/data/chromadb
ALERT_CHROMADB_HOST=chromadb
ALERT_CHROMADB_PORT=8000

# ==========================================
# Logging & Monitoring
# ==========================================
LOG_LEVEL=INFO
PYTHONPATH=/app

# ==========================================
# Security Settings
# ==========================================
UVICORN_WORKERS=2
UVICORN_ACCESS_LOG=-

# ==========================================
# API Rate Limiting
# ==========================================
ALERT_RATE_LIMIT=1000
ALERT_RATE_WINDOW=60

# ==========================================
# CORS Configuration
# ==========================================
CORS_ORIGINS=*
CORS_CREDENTIALS=true
CORS_METHODS=GET,POST,PUT,DELETE,OPTIONS
CORS_HEADERS=Content-Type,Authorization

# ==========================================
# GUI Configuration
# ==========================================
ALERT_GUI_BASE_URL=http://alert-analyzer-api:8002
ALERT_GUI_PORT=8080
GUI_SESSION_TIMEOUT=3600
GUI_ANALYTICS_ENABLED=false